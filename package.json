{
  "name": "vibe-phrasing-image-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 5174\" \"tsx src/http-server.ts --port 43110\" \"wait-on http://127.0.0.1:5174 http://127.0.0.1:43110/health && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 electron electron/main.cjs\"",
    "dev:http": "tsx src/http-server.ts --port 43110",
    "dev:mcp": "tsx src/mcp-server.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx src/smoke-test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "express": "^5.1.0",
    "sharp": "^0.34.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^37.3.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "wait-on": "^8.0.4"
  }
}
